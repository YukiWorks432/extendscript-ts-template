{
  "compilerOptions": {
    "target": "ES3",
    "module": "ESNext",
    "lib": [
      "ES5",
      "ES2015.Core",
      "ES2015.Collection",
      "ES2015.Iterable",
      "ES2015.Generator",
      "ES2015.Proxy",
      "ES2015.Reflect"
    ],
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "rootDir": "./src",
    "outDir": "./dist",
    "ignoreDeprecations": "5.0",
    "types": [
      "./node_modules/types-for-adobe/shared/global",
      "./node_modules/types-for-adobe/shared/PlugPlugExternalObject",
      "./node_modules/types-for-adobe/shared/ScriptUI"
    ]
  },
  "include": ["src/lib/**/*", "src/types/**/*", "src/init.ts", "src/tests/**/*"]
}
